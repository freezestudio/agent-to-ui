{
  "name": "a2a-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "start:server": "vp run @a2a-dev/example#start:server",
    "start:client": "vp run @a2a-dev/example#start:client",
    "start": "vp run @a2a-dev/example#start:server",
    "demo": "vp run @a2a-dev/example#demo",
    "start:agent": "vp run @a2a-dev/a2ui-agent#start",
    "start:angular": "cd apps/a2ui-angular && npx ng serve --port 5173"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
